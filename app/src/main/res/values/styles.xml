<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CustomProgressBarStyle" parent="Widget.AppCompat.ProgressBar">
        <item name="android:indeterminateTint">@android:color/white</item>
        <item name="android:indeterminateTintMode">src_in</item>
    </style> <!-- Material AlertDialog style -->
    <style name="AlertDialogStyle" parent="Theme.MaterialComponents.Light.Dialog">
        <!-- Set the background color of the dialog to white -->
        <item name="android:windowBackground">@android:color/white</item>
        <!-- Title and text color in the dialog -->
        <item name="android:textColorPrimary">@android:color/black</item>
        <item name="android:textColorSecondary">@android:color/darker_gray</item>
        <!-- Optional: Set the minimum width to a certain percentage -->
        <item name="android:windowMinWidthMinor">85%</item>
    </style>




</resources>