<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape>
                    <corners android:radius="12dp" />
                    <solid android:color="#26FF0000" /> </shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape>
                    <corners android:radius="10dp" />
                    <solid android:color="#1A050000" />
                    <stroke android:width="2dp" android:color="#FFFF2A2A" /> </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <shape>
            <corners android:radius="12dp" />
            <solid android:color="#0D000000" />
            <stroke android:width="1.5dp" android:color="#4DFF2A2A" /> </shape>
    </item>
</selector>
