<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="@drawable/bg_gothic_castle">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A6000000" />

    <com.CrimsonVeilDev.utils.ParticleView
        android:id="@+id/particle_engine"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <RelativeLayout
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="32dp">

        <View
            android:id="@+id/loginCardGlow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/loginCard"
            android:layout_alignBottom="@id/loginCard"
            android:background="@drawable/gothic_card_glow_blur"
            android:alpha="0.2" />

        <LinearLayout
            android:id="@+id/loginCard"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:background="@drawable/gothic_card_bg"
            android:gravity="center_horizontal"
            android:padding="28dp"
            android:orientation="vertical"
            android:elevation="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="16dp"
                    android:text="Crimson"
                    android:textColor="#FF2A2A"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2" />

                <View
                    android:id="@+id/moonTargetAnchor"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:visibility="invisible" />
            </RelativeLayout>

            <FrameLayout
                android:id="@+id/inputLayoutWrap"
                android:layout_height="58dp"
                android:layout_width="match_parent"
                android:layout_marginTop="24dp"
                android:background="@drawable/gothic_input_states">

                <TextView
                    android:id="@+id/animatedHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="16dp"
                    android:text="Please enter your access key..."
                    android:textColor="#66FFFFFF"
                    android:textSize="14sp"
                    android:letterSpacing="0.05" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <EditText
                        android:id="@+id/userkey"
                        android:layout_height="match_parent"
                        android:layout_width="0dp"
                        android:background="@android:color/transparent"
                        android:textColor="@android:color/white"
                        android:paddingStart="12dp"
                        android:layout_weight="1"
                        android:textSize="15sp"
                        android:inputType="text" />

                    <ImageView
                        android:id="@+id/paste"
                        android:layout_height="44dp"
                        android:layout_width="44dp"
                        android:src="@drawable/ic_content_paste"
                        android:contentDescription="Paste Key"
                        android:padding="10dp"
                        app:tint="#FF3B3B"
                        android:background="?attr/selectableItemBackgroundBorderless" />
                </LinearLayout>
            </FrameLayout>

            <Button
                android:id="@+id/login"
                android:layout_height="54dp"
                android:layout_width="match_parent"
                android:background="@drawable/gothic_button_bg"
                android:textAllCaps="true"
                android:textColor="@android:color/white"
                android:layout_marginTop="20dp"
                android:text="LOGIN"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:elevation="4dp" />

            <TextView
                android:id="@+id/GetKey"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:gravity="center"
                android:textColor="#FF4D4D"
                android:layout_marginTop="20dp"
                android:padding="8dp"
                android:text="Get Key"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
    </RelativeLayout>

    <FrameLayout
        android:id="@+id/moonSystem"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:elevation="20dp">

        <View
            android:id="@+id/moonOrbit"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/moon_orbit_ring" />

        <View
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/crimson_lunar_core" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/app_name_footer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vampire Node Terminal"
            android:textColor="#44FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/footer"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:textSize="11sp"
            android:textColor="#33FFFFFF"
            android:text="Copyright © 2026"
            android:letterSpacing="0.05"/>
    </LinearLayout>

</FrameLayout>
