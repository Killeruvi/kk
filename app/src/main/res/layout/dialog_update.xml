<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <!-- Glow Background -->
    <View
        android:id="@+id/bgGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/radial_glow_bg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:orientation="vertical"
        android:background="@drawable/glass_panel"
        android:elevation="32dp"
        android:padding="28dp">

        <!-- Animated Header Border -->
        <View
            android:id="@+id/borderGlow"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/horizontal_glow" />

        <!-- Title -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/alertTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="⚡ UPDATE NEXUS ⚡"
                android:textColor="#00FFCC"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <View
                android:id="@+id/titleUnderline"
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:layout_below="@id/alertTitle"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="6dp"
                android:background="@drawable/title_glow_line" />

        </RelativeLayout>

        <!-- Terminal Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/pulsing_dot" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="[ ACTIVE TERMINAL ]"
                android:textColor="#66FFCC"
                android:textSize="9sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/timeStamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="LIVE"
                android:textColor="#FF3366"
                android:textSize="9sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Terminal Log with Border -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/terminal_border"
            android:padding="2dp">

            <ScrollView
                android:id="@+id/logScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0A000000"
                android:padding="12dp"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/alertMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="5dp"
                    android:textColor="#CCFFCC"
                    android:textSize="11sp" />
            </ScrollView>

            <!-- Scan Line -->
            <View
                android:id="@+id/scanLine"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_gravity="top"
                android:background="@drawable/scan_glow" />

        </FrameLayout>

        <!-- Progress Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <!-- Percentage -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/progressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:text="0%"
                    android:textColor="#00FFCC"
                    android:textSize="44sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <!-- Progress Bar Container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="8dp"
                android:background="#1A00FFCC"
                android:padding="1dp">

                <!-- Fill Bar -->
                <View
                    android:id="@+id/progressFill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/neon_gradient" />

            </FrameLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/speedText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚡ 0 MB/s"
                    android:textColor="#66FFCC"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/etaText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="⏱️ ETA: --s"
                    android:textColor="#66FFCC"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/getKeyBtn"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/primary_button"
                android:text="⚡ GET KEY"
                android:textColor="#00FFCC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/alertButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/secondary_button"
                android:text="✖ CANCEL"
                android:textColor="#FF3366"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16px"
            android:text="◆ VAMPIRE NODE v3.0 ◆"
            android:textColor="#336666"
            android:textSize="8sp"
            android:alpha="0.6"
            android:fontFamily="monospace" />

    </LinearLayout>

</FrameLayout>