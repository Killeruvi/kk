<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gothic_castle">

    <androidx.appcompat.widget.SearchView
        android:id="@+id/appSearchView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@color/vampire_blood_red"
        android:iconifiedByDefault="false"
        android:queryHint="Search your apps..." />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/appRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/appSearchView"
        android:padding="8dp" />

</RelativeLayout>
